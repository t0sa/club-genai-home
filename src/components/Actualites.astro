---
interface Props {
  meetupUrl: string;
  meetupLabel: string;
  meetupDate: string;
  meetupLocation: string;
}

const { meetupUrl, meetupLabel, meetupDate, meetupLocation } = Astro.props;

let formattedDate: string | null = null;
if (meetupDate) {
  try {
    const d = new Date(meetupDate + 'T12:00:00');
    if (!Number.isNaN(d.getTime())) {
      formattedDate = d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
    }
  } catch { /* ignore malformed dates */ }
}
---
<section class="border-t border-sand">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <h2 class="mb-8 text-2xl font-bold text-charcoal">Actualités</h2>

    <div class="max-w-2xl">
      <a
        href={meetupUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-start gap-4 rounded-xl border border-l-4 border-sand border-l-terracotta bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
      >
        <div class="mt-0.5 flex-shrink-0 rounded-lg bg-terracotta/10 p-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-terracotta" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
          </svg>
        </div>

        <div class="flex-1 min-w-0">
          <p class="mb-1 text-xs font-medium uppercase tracking-wide text-stone">Prochain meetup</p>
          <h3 class="mb-3 text-base font-semibold text-charcoal transition-colors group-hover:text-terracotta">
            {meetupLabel}
          </h3>
          <div class="flex flex-wrap gap-4 text-sm text-stone">
            {formattedDate && (
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                </svg>
                {formattedDate}
              </span>
            )}
            {meetupLocation && (
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                {meetupLocation}
              </span>
            )}
          </div>
        </div>

        <span class="flex-shrink-0 self-center text-sm font-medium text-terracotta">
          Rejoindre →
        </span>
      </a>
    </div>
  </div>
</section>
