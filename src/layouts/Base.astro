---
import config from '../data/config.json';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Club GenAI — Bordeaux',
  description = 'Communauté IA générative à Bordeaux. Meetups, projets open source et veille GenAI.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
// Guard: Astro.site is undefined if `site` is not configured in astro.config.mjs
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;
// Anchor ogImage to site root + base path, not relative to canonicalURL's subpath
const ogImage = Astro.site ? new URL(`${base}club-genai-dark.svg`, Astro.site).href : null;
const githubUrl = `https://github.com/${config.github_user}`;
const sameAs = [githubUrl, config.meetup_group_url].filter((u): u is string => Boolean(u) && u.startsWith('http'));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Club GenAI Bordeaux',
  url: canonicalURL?.href,
  description,
  logo: ogImage,
  sameAs,
};
// Escape </script> sequences to prevent premature script-tag termination in HTML
const safeJsonLd = JSON.stringify(jsonLd).replace(/</g, '\\u003c');
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Anti-FOUC: applies saved theme before stylesheets render to prevent flash.
         Must use is:inline so Astro emits it verbatim (not bundled/deferred). -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {
          // localStorage unavailable (private browsing, browser policy) — default to light
        }
      })();
    </script>

    <!-- Preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Canonical -->
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="fr_FR" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    {canonicalURL && <meta property="og:url"   content={canonicalURL} />}
    {ogImage      && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" set:html={safeJsonLd} />

    <!-- Google Fonts — non-render-blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      />
    </noscript>

    <link rel="icon" type="image/svg+xml" href={`${base}club-genai-dark.svg`} />
  </head>
  <body class="bg-cream font-sans text-charcoal antialiased dark:bg-dark-bg dark:text-dark-text">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:bg-terracotta focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white dark:focus:bg-terracotta"
    >
      Aller au contenu principal
    </a>
    <slot />
  </body>
</html>
