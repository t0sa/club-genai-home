---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Club GenAI — Bordeaux',
  description = 'Communauté IA générative à Bordeaux. Meetups, projets open source et veille GenAI.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Anti-FOUC: applies saved theme before stylesheets render to prevent flash.
         Must use is:inline so Astro emits it verbatim (not bundled/deferred). -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {
          // localStorage unavailable (private browsing, browser policy) — default to light
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href={`${base}club-genai-dark.svg`} />
  </head>
  <body class="bg-cream font-sans text-charcoal antialiased dark:bg-dark-bg dark:text-dark-text">
    <slot />
  </body>
</html>
